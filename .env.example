# Telegram Bot Token (从 @BotFather 获取)
BOT_TOKEN=your_telegram_bot_token_here

# OpenClaw Gateway 配置
OPENCLAW_GATEWAY_URL=http://your-gateway-ip:18789
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Per-user OpenClaw 工作空间根目录 (每个用户自动创建 WORKSPACE_BASE/user_<userId>)
WORKSPACE_BASE=/root/.openclaw/multiuser-workspaces

# 数据库路径
DB_PATH=./data/multiuser.db

# 管理员 Telegram ID (逗号分隔)
ADMIN_IDS=123456789,987654321

# 流式传输 (true/false)
ENABLE_STREAMING=true
